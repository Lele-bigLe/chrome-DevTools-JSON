{
  "manifest_version": 3,
  "name": "JSON Structure Extractor",
  "description": "从 JSON 数据中提取数据结构，快速了解接口返回格式",
  "version": "1.0.1",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "JSON 数据结构提取器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "clipboardWrite",
    "clipboardRead",
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}